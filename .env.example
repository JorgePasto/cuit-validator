# ===== AMBIENTE =====
# Valores posibles: TEST, PROD
ENVIRONMENT=TEST

# ===== AFIP WSAA (Autenticación) =====
WSAA_URL_TEST=https://wsaahomo.afip.gov.ar/ws/services/LoginCms
WSAA_URL_PROD=https://wsaa.afip.gov.ar/ws/services/LoginCms

# ===== AFIP PADRÓN A13 (Consulta) =====
PADRON_URL_TEST=https://awshomo.afip.gov.ar/sr-padron/webservices/personaServiceA13
PADRON_URL_PROD=https://aws.afip.gov.ar/sr-padron/webservices/personaServiceA13

# ===== CERTIFICADOS AFIP =====
# Rutas a los certificados (relativas o absolutas)
AFIP_CERT_PATH=./certs/afip_cert.crt
AFIP_KEY_PATH=./certs/afip_private.key
# Passphrase de la clave privada (dejar vacío si no tiene)
AFIP_KEY_PASSPHRASE=
# CUIT de la organización (quien realiza las consultas, debe coincidir con el certificado)
AFIP_CUIT=xxxxxxxxxxxxxxxxx

# ===== CACHE =====
# Duración del cache de tokens en horas
TOKEN_CACHE_TTL_HOURS=12

# ===== LOGGING =====
# Niveles: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ===== SERVER =====
PORT=8000
HOST=127.0.0.1
